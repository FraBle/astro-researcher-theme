---
import { SEO } from "astro-seo";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import GoogleAnalytics from "../components/GoogleAnalytics.astro";
import CookieConsent from "../components/CookieConsent.astro";
import type { ResearcherConfig } from "../types";
import "../styles/researcher.scss";

interface Props {
  title: string;
  config: ResearcherConfig;
  noindex?: boolean;
  description?: string;
}

const { title, config, noindex, description } = Astro.props;
const isProd = import.meta.env.PROD;
const pageDescription = description || config.description;
const canonicalURL = config.site
  ? new URL(Astro.url.pathname, config.site).href
  : undefined;
const ogImage = config.openGraph?.image
  ? config.site
    ? new URL(config.openGraph.image, config.site).href
    : config.openGraph.image
  : undefined;
---

<!doctype html>
<html lang="en-us">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, shrink-to-fit=no"
    />
    <SEO
      title={title}
      description={pageDescription}
      canonical={canonicalURL}
      noindex={noindex}
      nofollow={noindex}
      openGraph={ogImage
        ? {
            basic: {
              title: title,
              type: config.openGraph?.type || "website",
              image: ogImage,
              url: canonicalURL,
            },
            optional: {
              description: pageDescription,
              locale: config.openGraph?.locale || "en_US",
              siteName: config.openGraph?.siteName || config.title,
            },
            image: {
              alt: title,
            },
          }
        : undefined}
      twitter={config.twitter
        ? {
            card: config.twitter.card || "summary",
            site: config.twitter.site,
            creator: config.twitter.creator,
            title: title,
            description: pageDescription,
            image: config.twitter.image
              ? config.site
                ? new URL(config.twitter.image, config.site).href
                : config.twitter.image
              : ogImage,
            imageAlt: title,
          }
        : undefined}
    />
    <meta name="author" content={config.author} />
    <link
      href="https://fonts.googleapis.com/css2?family=Inconsolata:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/4.6.2/css/bootstrap.min.css"
      integrity="sha512-rt/SrQ4UNIaGfDyEXZtNcyWvQeOq0QLygHluFQcSjaGB04IxWhal71tKuzP6K8eYXYB6vJV4pHkXcmFGGQ1/0w=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
      integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/academicons/1.9.3/css/academicons.min.css"
      integrity="sha512-vaoopdl+FJahyY2ddhsbDj8yDiRuyUYH/vIjF3z+cBg0sKc07NAQmUYli8volCGlW9OwlQyjVsr7Lh6qAManlw=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    {config.favicon && <link rel="icon" type="image/ico" href={config.favicon} />}
    {isProd && config.googleAnalyticsId && <GoogleAnalytics gaId={config.googleAnalyticsId} />}
  </head>
  <body>
    <Header title={config.title} nav={config.nav} />
    <div id="content">
      <slot />
    </div>
    <Footer footer={config.footer} />
    {isProd && config.consent && <CookieConsent items={config.consent.items} />}
  </body>
</html>
