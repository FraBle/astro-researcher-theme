---
interface Props {
  gaId: string;
}

const { gaId } = Astro.props;
---

<script define:vars={{ gaId }}>
  var dnt = navigator.doNotTrack || window.doNotTrack || navigator.msDoNotTrack;
  var doNotTrack = dnt == "1" || dnt == "yes";
  if (!doNotTrack) {
    window.dataLayer = window.dataLayer || [];
    function gtag() {
      dataLayer.push(arguments);
    }
    gtag("js", new Date());
    gtag("config", gaId);
  }
</script>
